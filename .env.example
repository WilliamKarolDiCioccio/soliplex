# =============================================================================
# Soliplex Environment Variables Example
# =============================================================================
# Copy this file to .env and configure with your actual values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env  # On Unix/Linux/Mac
#   # Or configure in docker-compose.yaml or your deployment system
# =============================================================================

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Ollama Configuration (if using Ollama)
# -----------------------------------------------------------------------------
# URL to your Ollama server (without /v1 suffix)
# For local Ollama: http://localhost:11434
# For Docker containers accessing host: http://host.docker.internal:11434
# For remote Ollama: http://your-ollama-server:11434
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# OpenAI Configuration (if using OpenAI)
# -----------------------------------------------------------------------------
# Your OpenAI API key
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# =============================================================================
# Soliplex Core Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Installation Path
# -----------------------------------------------------------------------------
# Path to your installation configuration directory
# Can be absolute path or file: URI
# Default: Current directory (file:.)
# SOLIPLEX_INSTALLATION_PATH=/app/installation

# -----------------------------------------------------------------------------
# URL Safe Token Secret
# -----------------------------------------------------------------------------
# Secret key for generating and validating MCP room tokens
# If not set, a random value is generated at startup (tokens will be invalidated on restart)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SOLIPLEX_URL_SAFE_TOKEN_SECRET=your-secret-token-here

# -----------------------------------------------------------------------------
# MCP Token Expiration (Optional)
# -----------------------------------------------------------------------------
# Maximum age in seconds for MCP room server tokens
# Uncomment to expire tokens after specified time
# Default: No expiration
# MCP_TOKEN_MAX_AGE=3600

# =============================================================================
# Observability & Logging
# =============================================================================

# -----------------------------------------------------------------------------
# Logfire Configuration (Optional)
# -----------------------------------------------------------------------------
# Pydantic Logfire token for observability and debugging
# Get from: https://logfire-us.pydantic.dev/
# LOGFIRE_TOKEN=pylf_v1_us_...

# Environment name for Logfire (e.g., development, staging, production, container)
# LOGFIRE_ENVIRONMENT=development

# Service name for Logfire
# LOGFIRE_SERVICE_NAME=soliplex

# =============================================================================
# External API Keys (Optional - for specific features)
# =============================================================================

# -----------------------------------------------------------------------------
# Smithery.AI MCP Tool Registry (Optional)
# -----------------------------------------------------------------------------
# Required only if using MCP tools from Smithery.AI registry
# Used in example/rooms/mcptest configuration
# Get from: https://smithery.ai/
# SMITHERY_AI_API_KEY=your-smithery-api-key
# SMITHERY_AI_PROFILE=your-profile-name

# -----------------------------------------------------------------------------
# Google Maps API (Optional)
# -----------------------------------------------------------------------------
# Required if using Google Maps tools in MCP configurations
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_MAPS_API_KEY=AIzaSy...

# =============================================================================
# Database Configuration (Advanced)
# =============================================================================

# -----------------------------------------------------------------------------
# RAG Database Path
# -----------------------------------------------------------------------------
# Path to LanceDB RAG database directory
# Default: file:../db/rag
# RAG_LANCE_DB_PATH=file:../db/rag

# -----------------------------------------------------------------------------
# Thread Persistence Database (Optional)
# -----------------------------------------------------------------------------
# SQLAlchemy DBURI for AG-UI thread persistence
#
# Synchronous (for CLI tools):
# Default: sqlite:// (in-memory)
# Example: sqlite:///path/to/threads.db
# Example: postgresql+psycopg2://user:password@host/dbname
# SOLIPLEX_THREAD_PERSISTENCE_SYNC_DBURI=sqlite://
#
# Asynchronous (for server):
# Default: sqlite+aiosqlite:// (in-memory)
# Example: sqlite+aiosqlite:///path/to/threads.db
# Example: postgresql+asyncpg://user:password@host/dbname
# SOLIPLEX_THREAD_PERSISTENCE_ASYNC_DBURI=sqlite+aiosqlite://

# -----------------------------------------------------------------------------
# Room Authorization Database (Optional)
# -----------------------------------------------------------------------------
# SQLAlchemy DBURI for room authorization policies
#
# Synchronous:
# SOLIPLEX_ROOM_AUTHZ_SYNC_DBURI=sqlite://
#
# Asynchronous:
# SOLIPLEX_ROOM_AUTHZ_ASYNC_DBURI=sqlite+aiosqlite://

# -----------------------------------------------------------------------------
# PostgreSQL Connection (if using PostgreSQL)
# -----------------------------------------------------------------------------
# Install asyncpg: pip install asyncpg
# Example connection string:
# POSTGRES_USER=soliplex
# POSTGRES_PASSWORD=your-password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=soliplex
#
# Then use in DBURIs:
# SOLIPLEX_THREAD_PERSISTENCE_SYNC_DBURI=postgresql+psycopg2://soliplex:your-password@localhost:5432/soliplex
# SOLIPLEX_THREAD_PERSISTENCE_ASYNC_DBURI=postgresql+asyncpg://soliplex:your-password@localhost:5432/soliplex

# =============================================================================
# Server Configuration (Advanced)
# =============================================================================

# -----------------------------------------------------------------------------
# Uvicorn Server Settings
# -----------------------------------------------------------------------------
# Number of worker processes
# Default: 1
# WEB_CONCURRENCY=1

# Trusted IP addresses for proxy headers (comma-separated)
# Used when running behind a reverse proxy
# Default: 127.0.0.1
# FORWARDED_ALLOW_IPS=127.0.0.1

# =============================================================================
# Development Settings (DO NOT USE IN PRODUCTION)
# =============================================================================

# -----------------------------------------------------------------------------
# Disable Authentication (Development Only)
# -----------------------------------------------------------------------------
# Set by --no-auth-mode flag, should not be set manually
# NEVER use in production!
# SOLIPLEX_NO_AUTH_MODE=true

# =============================================================================
# Application-Specific Secrets (Examples)
# =============================================================================

# The following are example secrets that might be used in custom configurations
# Configure based on your specific needs and external services

# -----------------------------------------------------------------------------
# Email Configuration (if using email features)
# -----------------------------------------------------------------------------
# ASKSAGE_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# Custom API Clients (if configured in your installation)
# -----------------------------------------------------------------------------
# DADS_API_CLIENT_SECRET_KEY=your-secret-key
# DADS_API_USERNAME=username
# DADS_API_PASSWORD=password

# -----------------------------------------------------------------------------
# Source Control Integration (if configured)
# -----------------------------------------------------------------------------
# GITEA_ACCESS_TOKEN=your-gitea-token
# GITHUB_TOKEN=your-github-token

# =============================================================================
# Notes
# =============================================================================
#
# 1. Security: Never commit .env file to version control
#    Add .env to .gitignore
#
# 2. Docker: When using docker-compose, this file is loaded automatically
#    via the env_file directive in docker-compose.yaml
#
# 3. Secret Management: For production, consider:
#    - Docker Secrets
#    - Kubernetes Secrets
#    - AWS Secrets Manager
#    - Azure Key Vault
#    - HashiCorp Vault
#
# 4. Configuration Files: Secrets can also be configured in installation YAML
#    using the secrets: section with various source types
#
# 5. Environment Variable Priority:
#    - Explicitly set environment variables (highest priority)
#    - .env file
#    - Installation YAML configuration
#    - System defaults (lowest priority)
#
# 6. Required vs Optional:
#    - OLLAMA_BASE_URL or OPENAI_API_KEY: Required (choose one)
#    - SOLIPLEX_URL_SAFE_TOKEN_SECRET: Recommended (auto-generated if missing)
#    - All others: Optional (feature-dependent)
#
# =============================================================================
