{
  "$defs": {
    "Citation": {
      "description": "Resolved citation with full metadata for display/visual grounding.",
      "properties": {
        "document_id": {
          "title": "Document Id",
          "type": "string"
        },
        "chunk_id": {
          "title": "Chunk Id",
          "type": "string"
        },
        "document_uri": {
          "title": "Document Uri",
          "type": "string"
        },
        "document_title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Document Title"
        },
        "page_numbers": {
          "items": {
            "type": "integer"
          },
          "title": "Page Numbers",
          "type": "array"
        },
        "headings": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headings"
        },
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "chunk_id",
        "document_uri",
        "content"
      ],
      "title": "Citation",
      "type": "object"
    },
    "QuestionResponseCitations": {
      "description": "Single question to the 'ask_with_rich_citations' tool\n\nIncludes response generated by the tool and accompanying citations.",
      "properties": {
        "question": {
          "title": "Question",
          "type": "string"
        },
        "response": {
          "title": "Response",
          "type": "string"
        },
        "citations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Citations",
          "type": "array"
        }
      },
      "required": [
        "question",
        "response"
      ],
      "title": "QuestionResponseCitations",
      "type": "object"
    }
  },
  "description": "History of questions asked and their replies + citations\n\nThis model describes the 'ask_history' key in the AG-UI state.\n\nEach call to the 'ask_with_rich_citations' took append",
  "properties": {
    "questions": {
      "default": [],
      "items": {
        "$ref": "#/$defs/QuestionResponseCitations"
      },
      "title": "Questions",
      "type": "array"
    }
  },
  "title": "AskedAndAnswered",
  "type": "object"
}